            </query>            
        </annotation-cqp-query>
        <metadata-cqp-query>
            <query>
                <query-expression><![CDATA[[norm="tudi"] within <TEXT-REGION="Ljubiljana"/>]]></query-expression>
                <explanation>will restrict the query to speech events whose metadata value for <form>TEXT-REGION</form> is <form>Ljubiljana</form></explanation>
            </query>
            <query>
                <query-expression><![CDATA[[norm="tudi"] within <DIALECT="pogovorni jezik"/>]]></query-expression>
                <explanation>will restrict the query to speakers whose metadata value for <form>DIALECT</form> is <form>pogovorni jezik</form></explanation>            
            </query>
        </metadata-cqp-query>        
    </section>
    
</zumult-query-examples>
