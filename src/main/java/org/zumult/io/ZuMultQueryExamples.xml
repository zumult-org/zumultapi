            </query>
            <query>
                <query-expression><![CDATA[[lemma="parlare"] within <regionMainActivity="Ticino"/>]]></query-expression>
                <explanation>will restrict the query to speakers whose metadata value for <form>regionMainActivity</form> is <form>Ticino</form></explanation>            
            </query>
        </metadata-cqp-query>        
    </section> 

    <section name="ROG" language="sl" corpus="ROG-Art">
