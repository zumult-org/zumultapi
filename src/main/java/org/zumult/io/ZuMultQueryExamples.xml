<?xml version="1.0" encoding="UTF-8"?>
<zumult-query-examples>
    <section name="Generic" language="en" corpus="EXMARaLDA-Demokorpus">
        <basic-query>
            <query>
                <query-expression>in</query-expression>
                <explanation>will find all tokens whose normalized form is <form>in</form></explanation>
            </query>
            <query>
                <query-expression>in the</query-expression>
                <explanation>will find <form>in</form> followed by <form>the</form> (normalized form)</explanation>
            </query>
        </basic-query>
        <simple-cqp-query>
            <query>
                <query-expression>[word="nice"]</query-expression>
                <explanation>will find all instances of the transcribed <form>nice</form></explanation>
            </query>
            <query>
                <query-expression>[norm="have"]</query-expression>
                <explanation>will find all instances whose normalized form is <form>have</form></explanation>
            </query>
            <query>
                <query-expression>[lemma="be"]</query-expression>
                <explanation>will find all instances whose lemma is <form>be</form></explanation>
            </query>
        </simple-cqp-query>
        <complex-cqp-query>
            <query>
                <query-expression>[lemma="klein"][pos="NN"]</query-expression>
                <explanation>will find forms of the lemma <form>klein</form> followed by a token with POS tag <form>NN</form> (a noun)</explanation>
            </query>
            <query>
                <query-expression>[norm="[Uu]n.+"]</query-expression>
                <explanation>will find all instances whose normalized form matches the regular expression, i.e. words starting in <form>Un</form> or <form>un</form></explanation>
            </query>
        </complex-cqp-query>        
        <annotation-cqp-query>
            <query>
                <query-expression><![CDATA[<en=".*good.*"/>]]></query-expression>
                <explanation>will find all spans whose English translation (<form>en</form>) contains <form>with</form></explanation>
            </query>
            <query>
                <query-expression><![CDATA[<sup="laut.*"/>]]></query-expression>
                <explanation>will find all spans annotated with something containing <form>laut</form> on the sup(rasegental) tier</explanation>
            </query>            
        </annotation-cqp-query>
        <metadata-cqp-query>
            <query>
                <query-expression><![CDATA[[norm="in"] within <Communication_type="television debate"/>]]></query-expression>
                <explanation>will restrict the query to speech events whose metadata value for <form>Communication type</form> is <form>television debate</form></explanation>
            </query>
            <query>
                <query-expression><![CDATA[[norm="in"] within <Role="Guest"/>]]></query-expression>
                <explanation>will restrict the query to speakers whose metadata value for <form>Role</form> is <form>Guest</form></explanation>            
            </query>
        </metadata-cqp-query>        
    </section>

