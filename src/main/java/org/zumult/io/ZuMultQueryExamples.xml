            </query>
        </simple-cqp-query>
        <complex-cqp-query>
            <query>
                <query-expression>[lemma="essere"][pos="ADJ"]</query-expression>
                <explanation>will find forms of the lemma <form>essere</form> followed by a token with POS tag <form>ADJ</form> (an adjective)</explanation>
            </query>
            <query>
