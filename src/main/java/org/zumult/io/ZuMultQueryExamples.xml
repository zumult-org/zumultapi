    <section name="TIGR" language="it" corpus="TIGR">
        <basic-query>
            <query>
                <query-expression>in</query-expression>
                <explanation>will find all tokens whose normalized form is <form>in</form></explanation>
            </query>
            <query>
                <query-expression>in realtà</query-expression>
                <explanation>will find <form>in</form> followed by <form>realtà</form> (normalized form)</explanation>
            </query>
        </basic-query>
        <simple-cqp-query>
            <query>
                <query-expression>[word="ancora"]</query-expression>
                <explanation>will find all instances of the transcribed <form>ancora</form></explanation>
            </query>
            <query>
                <query-expression>[norm="italiano"]</query-expression>
                <explanation>will find all instances whose normalized form is <form>italiano</form></explanation>
            </query>
            <query>
                <query-expression>[lemma="parlare"]</query-expression>
