            <query>
                <query-expression>tudi</query-expression>
                <explanation>will find all tokens whose normalized form is <form>tudi</form></explanation>
            </query>
            <query>
                <query-expression>in tudi</query-expression>
                <explanation>will find <form>in</form> followed by <form>tudi</form> (normalized form)</explanation>
            </query>
        </basic-query>
        <simple-cqp-query>
            <query>
                <query-expression>[word="tudi"]</query-expression>
                <explanation>will find all instances of the transcribed <form>nice</form></explanation>
            </query>
            <query>
                <query-expression>[norm="tudi"]</query-expression>
                <explanation>will find all instances whose normalized form is <form>have</form></explanation>
            </query>
            <query>
                <query-expression>[lemma="imeti"]</query-expression>
                <explanation>will find all instances whose lemma is <form>imeti</form></explanation>
            </query>
        </simple-cqp-query>
        <complex-cqp-query>
            <query>
                <query-expression>[lemma="imeti"][pos="ADJ"]</query-expression>
