                <explanation>will find all instances whose normalized form matches the regular expression, i.e. words starting in <form>obve</form></explanation>
            </query>
        </complex-cqp-query>        
        <annotation-cqp-query>
            <query>
                <query-expression><![CDATA[<disfluencyStructure="reparandum"/>]]></query-expression>
